{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["existingSecret"],
      "properties": {
        "existingSecret": {
          "type": "string",
          "minLength": 1,
          "description": "Name of an existing Secret with the Redis password."
        },
        "existingSecretPasswordKey": {
          "type": "string",
          "minLength": 1,
          "default": "password",
          "description": "Key in existingSecret (default: password)."
        }
      }
    },
    "config": {
      "type": "string",
      "minLength": 1
    },
    "configmapChecksumAnnotations": {
      "type": "boolean"
    },
    "authChecksumAnnotations": {
      "type": "boolean"
    },
    "revisionHistoryLimit": {
      "type": "integer",
      "minimum": 0
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "redis": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository", "tag"],
          "properties": {
            "repository": {
              "type": "string",
              "minLength": 1
            },
            "tag": {
              "type": "string",
              "minLength": 1
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "exporter": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository", "tag"],
          "properties": {
            "repository": {
              "type": "string",
              "minLength": 1
            },
            "tag": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "storageClass": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)?(E|P|T|G|M|K|Ei|Pi|Ti|Gi|Mi|Ki)$"
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "redis": {
          "$ref": "#/$defs/resourceRequirements"
        },
        "exporter": {
          "$ref": "#/$defs/resourceRequirements"
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "securityContext": {
      "type": "object"
    },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "minimum": 0
    }
  },
  "required": ["auth", "config"],
  "$defs": {
    "resourceRequirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requests": {
          "$ref": "#/$defs/resourceList"
        },
        "limits": {
          "$ref": "#/$defs/resourceList"
        }
      }
    },
    "resourceList": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
